# ─────────────────────────────────────────────
# Database (Neon PostgreSQL)
# ─────────────────────────────────────────────
# Pooled connection for the app (has -pooler in hostname)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
# Direct connection for Prisma CLI (migrations, db push — no -pooler)
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

# ─────────────────────────────────────────────
# Session (minimum 32 random characters)
# ─────────────────────────────────────────────
SESSION_SECRET="change-this-to-a-random-32-plus-character-string"

# ─────────────────────────────────────────────
# WhatsApp Cloud API (optional — falls back to console logging)
# ─────────────────────────────────────────────
WHATSAPP_API_URL="https://graph.facebook.com/v21.0/YOUR_PHONE_NUMBER_ID"
WHATSAPP_TOKEN="your-permanent-access-token"
VENDOR_WHATSAPP_PHONE="201551798114"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
